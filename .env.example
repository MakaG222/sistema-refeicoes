# ── Escola Naval — Sistema de Refeições ──────────────────────────────────
# Copiar para .env e ajustar valores antes de arrancar.
#
# Em desenvolvimento: basta correr `python app.py` sem definir nada.
# Em produção: SECRET_KEY e ENV=production são obrigatórios.

# ── Ambiente ─────────────────────────────────────────────────────────────
# "development" (default) ou "production"
ENV=development

# ── Segurança ────────────────────────────────────────────────────────────
# Obrigatório em produção. Gerar com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Token para endpoints cron (/api/backup-cron, /api/autopreencher-cron).
# Gerar com:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_API_TOKEN=

# ── Base de dados ────────────────────────────────────────────────────────
# Caminho para o ficheiro SQLite. Default: sistema.db na raiz do projecto.
# Em Railway: /mnt/data/sistema.db (volume persistente)
DB_PATH=sistema.db

# ── Negócio ──────────────────────────────────────────────────────────────
# Dias à frente que os alunos podem marcar refeições (inclui fins-de-semana)
DIAS_ANTECEDENCIA=15

# ── Servidor ─────────────────────────────────────────────────────────────
PORT=8080
DEBUG=false

# ── Backup offsite (opcional) ────────────────────────────────────────────
# Comando shell executado após cada backup diário para replicar offsite.
# O token {path} é substituído pelo caminho do ficheiro de backup.
# Sem shell: tokens via shlex.split (sem injecção).
# Exemplos:
#   BACKUP_UPLOAD_CMD="rclone copy {path} remote:backups/"
#   BACKUP_UPLOAD_CMD="aws s3 cp {path} s3://meu-bucket/backups/"
#   BACKUP_UPLOAD_CMD="rsync -a {path} backup-host:/srv/backups/"
# BACKUP_UPLOAD_CMD=
# BACKUP_UPLOAD_TIMEOUT=300

# ── Notificações operacionais (opcional) ─────────────────────────────────
# Backend: none (default) | stdout | webhook | smtp
# NOTIFICATION_BACKEND=none
#
# webhook:
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...
#
# smtp:
# NOTIFICATION_SMTP_HOST=smtp.example.com
# NOTIFICATION_SMTP_PORT=587
# NOTIFICATION_SMTP_USER=
# NOTIFICATION_SMTP_PASS=
# NOTIFICATION_SMTP_FROM=alerts@example.com
# NOTIFICATION_SMTP_TO=ops@example.com
# NOTIFICATION_SMTP_STARTTLS=1
